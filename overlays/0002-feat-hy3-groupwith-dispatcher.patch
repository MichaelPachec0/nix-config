+void Hy3Layout::groupWithOnWorkspace(
+    const CWorkspace* workspace,
+    ShiftDirection direction,
+    Hy3GroupLayout layout
+) {
+	auto* node = this->getWorkspaceFocusedNode(workspace);
+	if (node == nullptr) return;
+	this->groupWith(node->getPlacementActor(), direction, layout);
+}
+
+// Group the focused node together with its immediate sibling in `direction`
+// into a NEW group of `layout`, adding one level of nesting. Unlike makeGroup
+// (which wraps a single node) or movewindow (which moves a node into an
+// existing group, flattening when orientations match), this creates a fresh
+// parent containing exactly the two nodes -- e.g. with (a | (b|c)) focused on a
+// neighbour `d`, `groupwith l v` yields (a | ((b|c) - d)).
+void Hy3Layout::groupWith(Hy3Node& node, ShiftDirection direction, Hy3GroupLayout layout) {
+	node.assertNotRoot();
+
+	// The sibling we merge with must be adjacent at the same tree level.
+	auto* sibling = node.getImmediateSibling(direction);
+	if (sibling == nullptr) return;
+
+	// Wrap the sibling in a fresh group of the requested layout; the new group
+	// takes the sibling's slot in the (shared) parent. node stays put for now.
+	sibling->wrap(layout, GroupEphemeralityOption::Standard);
+	auto* group = sibling->parent.get();
+	if (group == nullptr || !group->is_group()) return;
+
+	// Detach the focused node from the shared parent and insert it into the new
+	// group on the correct side of the sibling.
+	auto node_up = node.parent->as_group().extractChild(node);
+	if (!node_up) return;
+
+	auto& dst = group->as_group();
+	bool forward = direction == ShiftDirection::Right || direction == ShiftDirection::Down;
+	if (forward) dst.insertChild(dst.children.begin(), std::move(node_up));
+	else dst.insertChild(std::move(node_up));
+
+	group->collapseParents(CollapsePolicy::InvalidOnly);
+	this->recalcGeometry();
+	node.focus(false, Desktop::FOCUS_REASON_KEYBIND);
+	this->recalcGeometry();
+}
