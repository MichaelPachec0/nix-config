+static SDispatchResult groupWith(ShiftDirection direction, Hy3GroupLayout layout) {
+	auto* hy3 = hy3InstanceForAction();
+	if (!hy3) return SDispatchResult {};
+
+	hy3->groupWithOnWorkspace(hy3->workspace().get(), direction, layout);
+	return SDispatchResult {};
+}
+
+static int luaGroupWith(lua_State* L) {
+	static constexpr const char* FN = "hl.plugin.hy3.group_with";
+	luaCheckArgCount(L, FN, 2, 2);
+
+	auto direction = luaShiftArg(L, 1, FN);
+	auto value = luaStringArg(L, 2, FN, "layout");
+	auto action = parseMakeGroupArg(value);
+	if (!action || action->opposite)
+		return luaL_error(L, "%s: invalid layout '%s' (expected h/v/tab)", FN, value.c_str());
+
+	auto dspGroupWith = [](lua_State* L) -> int {
+		auto direction = static_cast<ShiftDirection>(lua_tointeger(L, lua_upvalueindex(1)));
+		auto layout = static_cast<Hy3GroupLayout>(lua_tointeger(L, lua_upvalueindex(2)));
+		groupWith(direction, layout);
+		return 0;
+	};
+
+	lua_pushinteger(L, static_cast<lua_Integer>(direction));
+	lua_pushinteger(L, static_cast<lua_Integer>(action->layout));
+	lua_pushcclosure(L, dspGroupWith, 2);
+	return 1;
+}
+
+static SDispatchResult dispatch_groupwith(std::string value) {
+	auto args = CVarList(value);
+
+	auto direction = parseShiftArg(args[0]);
+	if (!direction) return SDispatchResult {};
+
+	auto action = parseMakeGroupArg(args[1]);
+	if (!action || action->opposite) return SDispatchResult {};
+
+	return groupWith(*direction, action->layout);
+}
