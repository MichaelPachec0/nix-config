-// hl.plugin.hy3.dump_tree("/path")() -- write the active workspace tree as JSON
-// to the given path. (hyprctl eval only returns "ok", so the tree is delivered
-// via a file the caller reads back.)
+// JSON for a specific workspace id's hy3 tree.
+static std::string dumpTreeJsonForWorkspace(int64_t id) {
+	auto ws = g_pCompositor->getWorkspaceByID(id);
+	std::stringstream buf;
+	dumpInstanceJson(buf, valid(ws) ? hy3InstanceForWorkspace(ws) : nullptr, id);
+	return buf.str();
+}
+
+// JSON for every live hy3 workspace, sorted by id:
+// [ {"workspace":N,"root":<node>}, ... ]
+static std::string dumpAllJson() {
+	std::map<int64_t, Hy3Layout*> instances;
+	for (auto* hy3: g_hy3Instances) {
+		auto ws = hy3 ? hy3->workspace() : nullptr;
+		instances[ws ? ws->m_id : -1] = hy3;
+	}
+
+	std::stringstream buf;
+	buf << "[";
+	bool first = true;
+	for (auto& [id, hy3]: instances) {
+		if (!first) buf << ",";
+		first = false;
+		dumpInstanceJson(buf, hy3, id);
+	}
+	buf << "]";
+	return buf.str();
+}
